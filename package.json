{
  "name": "mvj-ui",
  "version": "1.0.0",
  "private": true,
  "description": "City of Helsinki Land lease UI",
  "author": "Jori Lindell <jori.lindell@digia.com>",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "rm -rf dist && yarn build:leasing && yarn build:landuse",
    "build:leasing": "yarn workspace @mvj/leasing build",
    "build:landuse": "yarn workspace @mvj/landuse build",
    "dev:leasing": "yarn workspace @mvj/leasing dev",
    "dev:landuse": "yarn workspace @mvj/landuse dev",
    "lint": "eslint apps/**/src",
    "start": "yarn dev:leasing",
    "compile": "yarn build",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@sentry/react": "10.56.0",
    "final-form": "5.0.0",
    "final-form-arrays": "4.0.0",
    "hds-design-tokens": "5.2.0",
    "hds-react": "5.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-final-form": "6.5.9",
    "react-final-form-arrays": "4.0.0",
    "react-router-dom": "6.30.2"
  },
  "devDependencies": {
    "@babel/core": "7.28.5",
    "@babel/eslint-parser": "7.28.5",
    "@babel/preset-env": "7.28.5",
    "@babel/preset-react": "7.28.5",
    "@eslint/js": "9.39.1",
    "@rollup/plugin-babel": "6.1.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "24.12.4",
    "@types/react": "18.3.7",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "5.1.1",
    "@vitest/coverage-v8": "4.0.17",
    "@vitest/ui": "4.0.17",
    "eslint": "9.39.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "globals": "16.5.0",
    "jsdom": "27.2.0",
    "postcss": "8.5.6",
    "postcss-url": "10.1.3",
    "prettier": "3.6.2",
    "sass": "1.79.6",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.4",
    "vite": "7.2.2",
    "vite-plugin-commonjs": "0.10.4",
    "vite-plugin-static-copy": "3.1.4",
    "vitest": "4.0.17"
  },
  "resolutions": {
    "@types/react": "18.3.7",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "packageManager": "yarn@4.15.0"
}
